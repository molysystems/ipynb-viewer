{
  "name": "Notebook Viewer",
  "short_name": "NB Viewer",
  "description": "Android向けJupyter Notebookビューア",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "files": [
        {
          "name": "notebook",
          "accept": ["application/x-ipynb+json", ".ipynb"]
        }
      ]
    }
  }
}
